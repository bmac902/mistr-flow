# Claude Code OAuth token — runs the agent on your Claude subscription (Max),
# NOT the metered Anthropic API. Mint one on this host with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=
# Alternative (metered, pay-per-token, separate from Max) — use instead of the token above:
# ANTHROPIC_API_KEY=
# GitHub token — the agent uses it to read and manage GitHub Issues.
# Fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions: Issues (Read and write) and Metadata (Read)
GH_TOKEN=
